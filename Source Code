Sub ToggleKPIFilter()
    Dim wb As Workbook: Set wb = ActiveWorkbook
    Dim wsData As Worksheet, wsDash As Worksheet

    On Error Resume Next
    Set wsData = wb.Sheets("Delay Data")
    Set wsDash = wb.Sheets("Delay Dashboard")
    On Error GoTo 0
    If wsData Is Nothing Then Exit Sub
    Dim toggleCell As Range
    On Error Resume Next
    Set toggleCell = wb.Names("ToggleKPI").RefersToRange
    On Error GoTo 0
    If toggleCell Is Nothing Then Exit Sub
    Application.ScreenUpdating = False
    toggleCell.Value = Not toggleCell.Value
    Dim isListed As Boolean: isListed = toggleCell.Value
    Dim shpData As Shape, shpDash As Shape
    On Error Resume Next
    Set shpData = wsData.Shapes("btnKPI")
    Set shpDash = wsDash.Shapes("btnKPI")
    On Error GoTo 0
    Dim btnText As String, bgColor As Long, fontColor As Long
    If isListed Then
        btnText = "Delay in KPI Only: Listed"
        bgColor = RGB(198, 239, 206)
        fontColor = RGB(0, 97, 0)
    Else
        btnText = "Delay in KPI Only: Hidden"
        bgColor = RGB(255, 199, 206)
        fontColor = RGB(156, 0, 6)
    End If
    If Not shpData Is Nothing Then
        shpData.TextFrame.Characters.Text = btnText
        shpData.Fill.ForeColor.RGB = bgColor
        shpData.TextFrame.Characters.Font.Color = fontColor
    End If
    If Not shpDash Is Nothing Then
        shpDash.TextFrame.Characters.Text = btnText
        shpDash.Fill.ForeColor.RGB = bgColor
        shpDash.TextFrame.Characters.Font.Color = fontColor
    End If
    Application.Calculate
    ApplyDelayFilters wsData
    UpdateDashboardTables wb
    Application.ScreenUpdating = True
End Sub

