Sub ApplyDelayFilters(ws As Worksheet)
    Dim lo As ListObject
    On Error Resume Next
    Set lo = ws.ListObjects("TblDelays")
    On Error GoTo 0
    If Not lo Is Nothing Then
        Dim visIdx As Long
        visIdx = lo.ListColumns("Visibility Helper").Index
        lo.Range.AutoFilter Field:=visIdx, Criteria1:="1"
    End If
End Sub
