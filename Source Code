' ==============================================================
' DYNAMIC TABLE GENERATOR ENGINE
' ==============================================================
Sub UpdateDashboardTables(wb As Workbook)
    Dim wsData As Worksheet, wsDash As Worksheet
    On Error Resume Next
    Set wsData = wb.Sheets("Delay Data")
    Set wsDash = wb.Sheets("Delay Dashboard")
    On Error GoTo 0
    If wsData Is Nothing Or wsDash Is Nothing Then Exit Sub

    Dim lo As ListObject
    Set lo = wsData.ListObjects("TblDelays")
    If lo Is Nothing Then Exit Sub

    Dim dictCodes As Object
    Set dictCodes = CreateObject("Scripting.Dictionary")
    dictCodes.CompareMode = vbTextCompare

    Dim dictPenalties As Object
    Set dictPenalties = CreateObject("Scripting.Dictionary")
    dictPenalties.CompareMode = vbTextCompare

    ' New Dictionary Handlers
    Dim dictLanePie As Object, dictLaneCol As Object
    Set dictLanePie = CreateObject("Scripting.Dictionary"): dictLanePie.CompareMode = vbTextCompare
    Set dictLaneCol = CreateObject("Scripting.Dictionary"): dictLaneCol.CompareMode = vbTextCompare

    Dim visColIdx As Long, dCodeColIdx As Long, reasonColIdx As Long, accColIdx As Long, statusColIdx As Long
    Dim tatColIdx As Long, hblColIdx As Long, laneColIdx As Long, pAmtColIdx As Long, currColIdx As Long

    On Error Resume Next
    visColIdx = lo.ListColumns("Visibility Helper").Index
    dCodeColIdx = lo.ListColumns("Delay Code").Index
    reasonColIdx = lo.ListColumns("Reason").Index
    accColIdx = lo.ListColumns("Accountable").Index
    statusColIdx = lo.ListColumns("LSP Chargeability Status").Index
    tatColIdx = lo.ListColumns("TAT Penalty").Index
    hblColIdx = lo.ListColumns("HBL Number").Index
    laneColIdx = lo.ListColumns("Lane Key").Index
    pAmtColIdx = lo.ListColumns("Penalty Amt").Index
    currColIdx = lo.ListColumns("Currency").Index
    On Error GoTo 0
    If visColIdx = 0 Then Exit Sub

    Dim arrData As Variant
    arrData = lo.DataBodyRange.Value
    If IsEmpty(arrData) Then Exit Sub

    Dim i As Long, dCode As String
    For i = 1 To UBound(arrData, 1)
        If CStr(arrData(i, visColIdx)) = "1" Then
            dCode = Trim(CStr(arrData(i, dCodeColIdx)))

            If dCode = "" Or dCode = "-" Then dCode = "N/A"

            If Not dictCodes.exists(dCode) Then
                dictCodes.Add dCode, Array(1, arrData(i, reasonColIdx), arrData(i, accColIdx), arrData(i, statusColIdx))
            Else
                Dim tmp As Variant
                tmp = dictCodes(dCode)
                tmp(0) = tmp(0) + 1
                dictCodes(dCode) = tmp
            End If

            If tatColIdx > 0 Then
                Dim tpVal As Variant, tpStr As String
                tpVal = arrData(i, tatColIdx)

                If Trim(CStr(tpVal)) = "" Then
                    tpStr = "0%"
                ElseIf IsNumeric(tpVal) Then
                    tpStr = Format(tpVal, "0%")
                Else
                    tpStr = Trim(CStr(tpVal))
                End If

                If Not dictPenalties.exists(tpStr) Then
                    dictPenalties.Add tpStr, 1
                Else
                    dictPenalties(tpStr) = dictPenalties(tpStr) + 1
                End If
            End If

            ' New Chart Logic Extract
            If pAmtColIdx > 0 And laneColIdx > 0 And hblColIdx > 0 Then
                Dim pAmtVal As Variant
                pAmtVal = arrData(i, pAmtColIdx)
                If IsNumeric(pAmtVal) Then
                    If pAmtVal > 0 Then
                        Dim lk As String, hbl As String, currStr As String
                        lk = Trim(CStr(arrData(i, laneColIdx)))
                        hbl = Trim(CStr(arrData(i, hblColIdx)))
                        If currColIdx > 0 Then currStr = Trim(CStr(arrData(i, currColIdx))) Else currStr = ""
                        If lk = "" Then lk = "Unknown"

                        If Not dictLanePie.exists(lk) Then
                            dictLanePie.Add lk, 1
                        Else
                            dictLanePie(lk) = dictLanePie(lk) + 1
                        End If

                        If Not dictLaneCol.exists(lk) Then
                            dictLaneCol.Add lk, New Collection
                        End If
                        dictLaneCol(lk).Add Array(hbl, pAmtVal, currStr)
                    End If
                End If
            End If

        End If
    Next i

    Dim lastRow As Long
    lastRow = wsDash.Cells(wsDash.Rows.Count, "D").End(xlUp).Row
    If lastRow >= 4 Then
        wsDash.Range("D4:H" & lastRow).Clear
        wsDash.Range("D4:H" & lastRow).FormatConditions.Delete
    End If

    Dim lastRowA As Long
    lastRowA = wsDash.Cells(wsDash.Rows.Count, "A").End(xlUp).Row
    If lastRowA >= 13 Then
        wsDash.Range("A13:B" & lastRowA).Clear
        wsDash.Range("A13:B" & lastRowA).FormatConditions.Delete
    End If

    ' Clear previously stored Chart source arrays
    Dim lrP As Long, lrS As Long, lrX As Long
    lrP = wsDash.Cells(wsDash.Rows.Count, "P").End(xlUp).Row
    If lrP >= 4 Then wsDash.Range("P4:Q" & lrP).ClearContents

    lrS = wsDash.Cells(wsDash.Rows.Count, "T").End(xlUp).Row
    If lrS >= 4 Then wsDash.Range("T4:W" & lrS).ClearContents

    lrX = wsDash.Cells(wsDash.Rows.Count, "Y").End(xlUp).Row
    If lrX >= 4 Then wsDash.Range("Y4:Z" & lrX).ClearContents

    Dim r As Long: r = 4
    Dim k As Variant
    For Each k In dictCodes.Keys
        wsDash.Cells(r, "D").Value = k
        wsDash.Cells(r, "E").Value = dictCodes(k)(0)
        wsDash.Cells(r, "F").Value = dictCodes(k)(1)
        wsDash.Cells(r, "G").Value = dictCodes(k)(2)
        wsDash.Cells(r, "H").Value = dictCodes(k)(3)
        r = r + 1
    Next k

    If r > 5 Then
        Dim sortRng As Range
        Set sortRng = wsDash.Range("D3:H" & r - 1)
        With wsDash.Sort
            .SortFields.Clear
            .SortFields.Add key:=wsDash.Range("E4:E" & r - 1), SortOn:=xlSortOnValues, Order:=xlDescending, DataOption:=xlSortNormal
            .SetRange sortRng
            .Header = xlYes
            .Apply
        End With
    End If

    If r > 4 Then
        With wsDash.Range("H4:H" & r - 1).FormatConditions.Add(Type:=xlCellValue, Operator:=xlEqual, Formula1:="=""Chargeable""")
            .Interior.Color = RGB(198, 239, 206): .Font.Color = RGB(0, 97, 0)
        End With
        With wsDash.Range("H4:H" & r - 1).FormatConditions.Add(Type:=xlCellValue, Operator:=xlEqual, Formula1:="=""Not Chargeable""")
            .Interior.Color = RGB(255, 199, 206): .Font.Color = RGB(156, 0, 6)
        End With
        With wsDash.Range("H4:H" & r - 1).FormatConditions.Add(Type:=xlCellValue, Operator:=xlEqual, Formula1:="=""Missing""")
            .Interior.Color = RGB(255, 235, 156): .Font.Color = RGB(156, 101, 0)
        End With
    End If

    Dim rP As Long: rP = 13
    wsDash.Range("A13:A100").NumberFormat = "@"
    For Each k In dictPenalties.Keys
        wsDash.Cells(rP, "A").Value = k
        wsDash.Cells(rP, "B").Value = dictPenalties(k)
        rP = rP + 1
    Next k

    If rP > 14 Then
        Dim sortRngP As Range
        Set sortRngP = wsDash.Range("A13:B" & rP - 1)
        With wsDash.Sort
            .SortFields.Clear
            .SortFields.Add key:=wsDash.Range("B13:B" & rP - 1), SortOn:=xlSortOnValues, Order:=xlDescending, DataOption:=xlSortNormal
            .SetRange sortRngP
            .Header = xlNo
            .Apply
        End With
    End If

    If rP > 13 Then
        Dim pCell As Range
        For Each pCell In wsDash.Range("A13:A" & rP - 1)
            On Error Resume Next
            pCell.Errors(xlNumberAsText).Ignore = True
            On Error GoTo 0
        Next pCell

        With wsDash.Range("A13:A" & rP - 1).FormatConditions.Add(Type:=xlCellValue, Operator:=xlEqual, Formula1:="=""0%""")
            .Interior.Color = RGB(198, 239, 206): .Font.Color = RGB(0, 97, 0)
        End With
    End If

    ' Write Pie Data (Shifted Right to Column P & Q)
    Dim rK As Long: rK = 4
    For Each k In dictLanePie.Keys
        wsDash.Cells(rK, "P").Value = k
        wsDash.Cells(rK, "Q").Value = dictLanePie(k)
        rK = rK + 1
    Next k

    If rK > 5 Then
        Dim sortRngK As Range
        Set sortRngK = wsDash.Range("P3:Q" & rK - 1)
        With wsDash.Sort
            .SortFields.Clear
            .SortFields.Add key:=wsDash.Range("Q4:Q" & rK - 1), SortOn:=xlSortOnValues, Order:=xlDescending, DataOption:=xlSortNormal
            .SetRange sortRngK
            .Header = xlYes
            .Apply
        End With
    End If

    ' Write Total Grouped Data (Shifted Right to Column T, U, V, W + Adding Subtotals)
    Dim rN As Long: rN = 4
    Dim rT As Long: rT = 4
    For Each k In dictLaneCol.Keys
        Dim isFirst As Boolean: isFirst = True
        Dim cItem As Variant
        Dim tAmt As Double: tAmt = 0
        Dim lastC As String: lastC = ""

        For Each cItem In dictLaneCol(k)
            If isFirst Then
                wsDash.Cells(rN, "T").Value = k
                isFirst = False
            End If
            wsDash.Cells(rN, "U").Value = cItem(0)
            wsDash.Cells(rN, "V").Value = cItem(1)
            wsDash.Cells(rN, "W").Value = cItem(2)
            tAmt = tAmt + CDbl(cItem(1))
            lastC = cItem(2)
            rN = rN + 1
        Next cItem

        ' Append the Visual Subtotal Block
        wsDash.Cells(rN, "U").Value = "Total"
        wsDash.Cells(rN, "V").Value = tAmt
        wsDash.Cells(rN, "W").Value = lastC

        wsDash.Range(wsDash.Cells(rN, "U"), wsDash.Cells(rN, "W")).Font.Bold = True
        rN = rN + 2 ' Gap row between blocks

        ' Silently populate background summary table (Y & Z) to serve the Column Chart
        wsDash.Cells(rT, "Y").Value = k
        wsDash.Cells(rT, "Z").Value = tAmt
        rT = rT + 1
    Next k

    ' Target Existing Charts for Synced Updates
    Dim cho As ChartObject
    On Error Resume Next
    Set cho = wsDash.ChartObjects("DelayCodesPieChart")
    On Error GoTo 0
    If Not cho Is Nothing Then
        If r > 4 Then
            cho.Chart.SetSourceData Source:=wsDash.Range("D3:E" & r - 1)
            cho.Visible = msoTrue
        Else
            cho.Visible = msoFalse
        End If
    End If

    Dim cho4 As ChartObject
    On Error Resume Next
    Set cho4 = wsDash.ChartObjects("TATPenaltyPieChart")
    On Error GoTo 0
    If Not cho4 Is Nothing Then
        If rP > 13 Then
            cho4.Chart.SetSourceData Source:=wsDash.Range("A12:B" & rP - 1), PlotBy:=xlColumns
            If cho4.Chart.SeriesCollection.Count > 0 Then
                On Error Resume Next
                cho4.Chart.SeriesCollection(1).XValues = wsDash.Range("A13:A" & (rP - 1))
                cho4.Chart.SeriesCollection(1).Values = wsDash.Range("B13:B" & (rP - 1))
                On Error GoTo 0
            End If
            cho4.Visible = msoTrue
        Else
            cho4.Visible = msoFalse
        End If
    End If

    Dim cho5 As ChartObject
    On Error Resume Next
    Set cho5 = wsDash.ChartObjects("LaneKeyPieChart")
    On Error GoTo 0
    If Not cho5 Is Nothing Then
        If rK > 4 Then
            cho5.Chart.SetSourceData Source:=wsDash.Range("P3:Q" & (rK - 1)), PlotBy:=xlColumns
            cho5.Visible = msoTrue
        Else
            cho5.Visible = msoFalse
        End If
    End If

    Dim cho6 As ChartObject
    On Error Resume Next
    Set cho6 = wsDash.ChartObjects("TotalPenaltyColumnChart")
    On Error GoTo 0
    If Not cho6 Is Nothing Then
        If rT > 4 Then
            cho6.Chart.SetSourceData Source:=wsDash.Range("Y3:Z" & (rT - 1)), PlotBy:=xlColumns
            cho6.Visible = msoTrue
        Else
            cho6.Visible = msoFalse
        End If
    End If
End Sub

' ==============================================================
' HELPER FUNCTIONS
' ==============================================================
Function ExtractNumeric(ByVal rawVal As Variant) As Variant
    If IsEmpty(rawVal) Or IsNull(rawVal) Then
        ExtractNumeric = ""
        Exit Function
    End If
    If IsNumeric(rawVal) Then
        ExtractNumeric = CDbl(rawVal)
        Exit Function
    End If

    Dim strVal As String, i As Integer, c As String
    Dim numStr As String, hasDot As Boolean
    strVal = Trim(CStr(rawVal))

    For i = 1 To Len(strVal)
        c = Mid(strVal, i, 1)
        If c Like "[0-9]" Then
            numStr = numStr & c
        ElseIf c = "." And Not hasDot Then
            numStr = numStr & c
            hasDot = True
        End If
    Next i

    If numStr <> "" And numStr <> "." Then
        ExtractNumeric = CDbl(numStr)
    Else
        ExtractNumeric = ""
    End If
End Function

Function OpenWorkbookSafely(filePath As String) As Workbook
    Dim wb As Workbook, fileName As String
    fileName = Mid(filePath, InStrRev(filePath, "\") + 1)
    On Error Resume Next
    Set wb = Workbooks.Open(filePath, ReadOnly:=True)
    If wb Is Nothing Then Set wb = Workbooks(fileName)
    On Error GoTo 0
    Set OpenWorkbookSafely = wb
End Function

Function FindExactHeaderCol(ws As Worksheet, headerName As String, maxRow As Long) As Long
    Dim r As Long, c As Long
    For r = 1 To maxRow
        For c = 1 To 150
            If StrComp(Trim(CStr(ws.Cells(r, c).Value)), headerName, vbTextCompare) = 0 Then
                FindExactHeaderCol = c
                Exit Function
            End If
        Next c
    Next r
    FindExactHeaderCol = 0
End Function

Function FindSmartHeaderCol(ws As Worksheet, headerType As String, maxRow As Long, requiresDate As Boolean) As Long
    Dim r As Long, c As Long, i As Long, e As Long, cellVal As String, cleanCell As String, cleanAlias As String
    Dim aliases As Variant, exclusions As Variant
    exclusions = Array("STATUS", "NAME", "REMARK", "COMMENT", "LINK", "FILE", "SIGNATURE", "TYPE", "REASON", "ELEMENT", "PLANNED", "EXPECTED", "ESTIMATED")
    Select Case UCase(headerType)
        Case "HAWB": aliases = Array("HBLHAWB", "HAWB", "HBL", "HOUSEBILL", "BILLOFLADING")
        Case "SVC": aliases = Array("SERVICELEVEL", "SVCLEVEL")
        Case "APD": aliases = Array("ACTUALPICKUPDATEAPD", "ACTUALPICKUPDATE", "ACTUALPICKUP", "APD")
        Case "ATD": aliases = Array("ACTUALTIMEOFDEPARTUREATD", "ACTUALTIMEOFDEPARTURE", "ATD", "TIMEOFDEPARTURE")
        Case "ATA": aliases = Array("ACTUALTIMEOFARRIVALATA", "ACTUALTIMEOFARRIVAL", "ATA", "TIMEOFARRIVAL")
        Case "POD": aliases = Array("PROOFOFDELIVERYDATE", "PROOFOFDELIVERY", "POD", "DELIVERYDATE")
        Case "SC": aliases = Array("STARTCLOCK", "CLOCKSTART", "SCDATE")
        Case "TRANSIT": aliases = Array("TOTALTRANSITTIME", "TOTALDAYSACTUALTAT", "TRANSITTIME", "TRANSITDAYS", "TOTALTRANSIT")
        Case "DELAY": aliases = Array("BOSCHDELAYCODE", "DELAYCODE", "REASONCODE", "EXCEPTIONCODE")
    End Select
    For r = 1 To maxRow
        For c = 1 To 150
            cellVal = CStr(ws.Cells(r, c).Value2)
            If cellVal <> "" Then
                cleanCell = Replace(Replace(Replace(Replace(Replace(Replace(Replace(Replace(UCase(cellVal), " ", ""), "-", ""), "_", ""), "/", ""), "(", ""), ")", ""), vbLf, ""), vbCr, "")
                Dim isExcluded As Boolean: isExcluded = False
                For e = LBound(exclusions) To UBound(exclusions)
                    If InStr(1, cleanCell, exclusions(e)) > 0 Then isExcluded = True: Exit For
                Next e
                If Not isExcluded Then
                    For i = LBound(aliases) To UBound(aliases)
                        cleanAlias = UCase(aliases(i))
                        If InStr(1, cleanCell, cleanAlias) > 0 Then
                            If headerType = "ATD" And InStr(1, cleanCell, "ARRIVAL") > 0 Then GoTo NextAlias
                            If headerType = "ATA" And InStr(1, cleanCell, "DEPARTURE") > 0 Then GoTo NextAlias
                            If requiresDate Then
                                Dim checkRow As Long, nonBlankCount As Integer, dateCount As Integer
                                nonBlankCount = 0: dateCount = 0
                                For checkRow = r + 1 To ws.Cells(ws.Rows.Count, c).End(xlUp).Row
                                    If checkRow > r + 30 Then Exit For
                                    Dim testVal As Variant: testVal = ws.Cells(checkRow, c).Value2
                                    If Trim(CStr(testVal)) <> "" Then
                                        nonBlankCount = nonBlankCount + 1
                                        Dim parsed As Date: parsed = ParseSafeDate(testVal)
                                        If parsed > DateSerial(2000, 1, 1) And parsed < DateSerial(2100, 1, 1) Then dateCount = dateCount + 1
                                        If nonBlankCount >= 5 Then Exit For
                                    End If
                                Next checkRow
                                If nonBlankCount > 0 And dateCount = 0 Then GoTo NextAlias
                            End If
                            FindSmartHeaderCol = c
                            Exit Function
                        End If
NextAlias:
                    Next i
                End If
            End If
        Next c
    Next r
    FindSmartHeaderCol = 0
End Function

Function GetOriginRegion(countryCode As String, postCode As String, dictOrigRegs As Object) As String
    Dim clnPost As String
    clnPost = Trim(postCode)
    
    Dim derivedOrig As String: derivedOrig = ""
    If dictOrigRegs.exists(UCase(Trim(countryCode))) Then
        Dim colRegs As Collection: Set colRegs = dictOrigRegs(UCase(Trim(countryCode)))
        
        ' Shortcut: If there is only 1 region for the country, just use it
        If colRegs.Count = 1 Then
            GetOriginRegion = CStr(colRegs(1))
            Exit Function
        End If
        
        Dim vReg As Variant, regStr As String, insideP As String, bounds() As String
        Dim bStart As String, bEnd As String
        Dim extLen As Integer, extStr As String, extVal As Integer
        
        For Each vReg In colRegs
            regStr = CStr(vReg)
            If InStr(regStr, "(") > 0 And InStr(regStr, ")") > 0 Then
                insideP = Mid(regStr, InStr(regStr, "(") + 1, InStr(regStr, ")") - InStr(regStr, "(") - 1)
                
                If InStr(insideP, "-") > 0 Then
                    bounds = Split(insideP, "-")
                    bStart = Trim(bounds(0))
                    bEnd = Trim(bounds(1))
                    
                    If IsNumeric(bStart) And IsNumeric(bEnd) Then
                        ' 1. Check the length based on the starting bound (e.g. 1 digit for 0-5)
                        extLen = Len(bStart)
                        If Len(clnPost) >= extLen Then
                            extStr = Left(clnPost, extLen)
                            If IsNumeric(extStr) Then
                                extVal = CInt(extStr)
                                If extVal >= CInt(bStart) And extVal <= CInt(bEnd) Then
                                    derivedOrig = regStr: Exit For
                                End If
                            End If
                        End If
                        
                        ' 2. Edge Case Check: If bounds have different lengths (e.g. "9-12")
                        ' Check the length of the upper bound just in case
                        If Len(bEnd) <> Len(bStart) And derivedOrig = "" Then
                            extLen = Len(bEnd)
                            If Len(clnPost) >= extLen Then
                                extStr = Left(clnPost, extLen)
                                If IsNumeric(extStr) Then
                                    extVal = CInt(extStr)
                                    If extVal >= CInt(bStart) And extVal <= CInt(bEnd) Then
                                        derivedOrig = regStr: Exit For
                                    End If
                                End If
                            End If
                        End If
                    End If
                    
                ElseIf IsNumeric(Trim(insideP)) Then
                    ' Single exact match logic (e.g., "Paris (75)")
                    extLen = Len(Trim(insideP))
                    If Len(clnPost) >= extLen Then
                        extStr = Left(clnPost, extLen)
                        If IsNumeric(extStr) Then
                            If CInt(extStr) = CInt(Trim(insideP)) Then
                                derivedOrig = regStr: Exit For
                            End If
                        End If
                    End If
                End If
            End If
        Next vReg
        
        ' Fallback 1: If no match, look for a generic region without brackets
        If derivedOrig = "" Then
            For Each vReg In colRegs
                regStr = CStr(vReg)
                If InStr(regStr, "(") = 0 Then derivedOrig = regStr: Exit For
            Next vReg
        End If
        
        ' Fallback 2: Assign the first available region so it doesn't break
        If derivedOrig = "" And colRegs.Count > 0 Then derivedOrig = CStr(colRegs(1))
    End If
    
    If derivedOrig = "" Then derivedOrig = "Unmapped Origin"
    GetOriginRegion = derivedOrig
End Function

Function GetSafeArrayVal(arr As Variant, rowIdx As Long, colIdx As Long) As Variant
    If colIdx > 0 And colIdx <= UBound(arr, 2) Then GetSafeArrayVal = arr(rowIdx, colIdx) Else GetSafeArrayVal = Empty
End Function

Function ParseSafeDate(ByVal val As Variant) As Date
    If IsEmpty(val) Or val = "" Then ParseSafeDate = 0: Exit Function
    If VarType(val) = vbDate Or VarType(val) = vbDouble Then ParseSafeDate = Int(CDbl(val)): Exit Function
    Dim sVal As String, dPart As String, strArr() As String, parts() As String
    sVal = Replace(Trim(CStr(val)), Chr(160), " ")
    strArr = Split(sVal, " "): dPart = strArr(0)
    parts = Split(dPart, "/")
    If UBound(parts) = 0 Then parts = Split(dPart, "-")
    If UBound(parts) = 2 Then
        If IsNumeric(parts(0)) And IsNumeric(parts(1)) And IsNumeric(parts(2)) Then
            Dim p0 As Integer, p1 As Integer, p2 As Integer
            p0 = CInt(parts(0)): p1 = CInt(parts(1)): p2 = CInt(parts(2))
            If p2 < 100 Then p2 = p2 + 2000
            If p0 > 12 And p1 <= 12 Then ParseSafeDate = DateSerial(p2, p1, p0): Exit Function
            If p1 > 12 And p0 <= 12 Then ParseSafeDate = DateSerial(p2, p0, p1): Exit Function
        End If
    End If
    On Error Resume Next
    ParseSafeDate = Int(CDbl(CDate(dPart)))
    If Err.Number <> 0 Then ParseSafeDate = Int(CDbl(CDate(val)))
    On Error GoTo 0
End Function

Function CleanSvc(ByVal svc As String) As String
    Dim s As String
    s = UCase(Trim(svc))
    s = Replace(s, "SERVICE", "")
    s = Replace(s, "LEVEL", "")
    s = Replace(s, " ", "")
    CleanSvc = s
End Function

