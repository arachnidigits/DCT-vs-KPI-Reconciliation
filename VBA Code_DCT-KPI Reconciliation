    Dim shpPOD As Shape
    Set shpPOD = wsDelayTab.Shapes.AddShape(msoShapeRoundedRectangle, 0, 0, 210, 25)
    shpPOD.Name = "btnPOD"
    shpPOD.TextFrame.Characters.Text = "POD Discrepancies: Listed"
    shpPOD.TextFrame.VerticalAlignment = xlVAlignCenter
    shpPOD.TextFrame.HorizontalAlignment = xlHAlignCenter
    shpPOD.TextFrame.Characters.Font.Color = RGB(0, 97, 0)
    shpPOD.TextFrame.Characters.Font.Bold = msoTrue
    shpPOD.Fill.ForeColor.RGB = RGB(198, 239, 206)
    shpPOD.Line.Visible = msoFalse
    shpPOD.OnAction = "'" & ThisWorkbook.Name & "'!TogglePODFilter"

    wsDelayTab.Range("A4:P4").Value = Array("HBL Number", "Scenario", "Start Clock (DCT)", "Start Clock (KPI)", "Contracted Transit Time", "Actual Transit Time (DCT)", "Contracted Delivery Date (DCT)", "Compare Date (DCT)", "Compare Date (KPI)", "Delay Code", "Reason", "Accountable", "LSP Chargeability Status", "SC Discrepancy", "POD Discrepancy", "Visibility Helper")
    
    Dim rDelay As Long: rDelay = dRow - 1: If rDelay < 1 Then rDelay = 1
    If dRow > 1 Then wsDelayTab.Range("A5").Resize(rDelay, 16).Value = outDelay
    
    With wsDelayTab.Range("A4:P4")
        .Interior.ThemeColor = xlThemeColorAccent2: .Interior.TintAndShade = 0.4: .Font.Bold = True
    End With
    
    Set lo = wsDelayTab.ListObjects.Add(xlSrcRange, wsDelayTab.Range("A4:P" & 4 + rDelay), , xlYes)
