Function OpenWorkbookSafely(filePath As String) As Workbook
    Dim wb As Workbook, fileName As String
    fileName = Mid(filePath, InStrRev(filePath, "\") + 1)
    On Error Resume Next
    Set wb = Workbooks.Open(filePath, ReadOnly:=True)
    If wb Is Nothing Then Set wb = Workbooks(fileName)
    On Error GoTo 0
    Set OpenWorkbookSafely = wb
End Function

Function FindExactHeaderCol(ws As Worksheet, headerName As String, maxRow As Long) As Long
    Dim r As Long, c As Long
    For r = 1 To maxRow
        For c = 1 To 150
            If Trim(CStr(ws.Cells(r, c).Value)) = headerName Then
                FindExactHeaderCol = c
                Exit Function
            End If
        Next c
    Next r
    FindExactHeaderCol = 0
End Function

Function FindSmartHeaderCol(ws As Worksheet, headerType As String, maxRow As Long, requiresDate As Boolean) As Long
    Dim r As Long, c As Long, i As Long, e As Long, cellVal As String, cleanCell As String, cleanAlias As String
    Dim aliases As Variant, exclusions As Variant
    exclusions = Array("STATUS", "NAME", "REMARK", "COMMENT", "LINK", "FILE", "SIGNATURE", "TYPE", "REASON", "ELEMENT", "PLANNED", "EXPECTED", "ESTIMATED")
    Select Case UCase(headerType)
        Case "HAWB": aliases = Array("HBLHAWB", "HAWB", "HBL", "HOUSEBILL", "BILLOFLADING")
        Case "SVC": aliases = Array("SERVICELEVEL", "SVCLEVEL")
        Case "APD": aliases = Array("ACTUALPICKUPDATEAPD", "ACTUALPICKUPDATE", "ACTUALPICKUP", "PICKUPDATE", "APD")
        Case "ATD": aliases = Array("ACTUALTIMEOFDEPARTUREATD", "ACTUALTIMEOFDEPARTURE", "ATD", "TIMEOFDEPARTURE")
        Case "ATA": aliases = Array("ACTUALTIMEOFARRIVALATA", "ACTUALTIMEOFARRIVAL", "ATA", "TIMEOFARRIVAL")
        Case "POD": aliases = Array("PROOFOFDELIVERYDATE", "PROOFOFDELIVERY", "POD", "DELIVERYDATE")
        Case "SC": aliases = Array("STARTCLOCK", "CLOCKSTART", "SCDATE")
        Case "TRANSIT": aliases = Array("TOTALTRANSITTIME", "TOTALDAYSACTUALTAT", "TRANSITTIME", "TRANSITDAYS", "TOTALTRANSIT")
        Case "DELAY": aliases = Array("BOSCHDELAYCODE", "DELAYCODE", "REASONCODE", "EXCEPTIONCODE")
    End Select
    For r = 1 To maxRow
        For c = 1 To 150
            cellVal = CStr(ws.Cells(r, c).Value2)
            If cellVal <> "" Then
                cleanCell = Replace(Replace(Replace(Replace(Replace(Replace(Replace(Replace(UCase(cellVal), " ", ""), "-", ""), "_", ""), "/", ""), "(", ""), ")", ""), vbLf, ""), vbCr, "")
                Dim isExcluded As Boolean: isExcluded = False
                For e = LBound(exclusions) To UBound(exclusions)
                    If InStr(1, cleanCell, exclusions(e)) > 0 Then isExcluded = True: Exit For
                Next e
                If Not isExcluded Then
                    For i = LBound(aliases) To UBound(aliases)
                        cleanAlias = UCase(aliases(i))
                        If InStr(1, cleanCell, cleanAlias) > 0 Then
                            If headerType = "ATD" And InStr(1, cleanCell, "ARRIVAL") > 0 Then GoTo NextAlias
                            If headerType = "ATA" And InStr(1, cleanCell, "DEPARTURE") > 0 Then GoTo NextAlias
                            If requiresDate Then
                                Dim checkRow As Long, nonBlankCount As Integer, dateCount As Integer
                                nonBlankCount = 0: dateCount = 0
                                For checkRow = r + 1 To ws.Cells(ws.Rows.Count, c).End(xlUp).Row
                                    If checkRow > r + 30 Then Exit For
                                    Dim testVal As Variant: testVal = ws.Cells(checkRow, c).Value2
                                    If Trim(CStr(testVal)) <> "" Then
                                        nonBlankCount = nonBlankCount + 1
                                        Dim parsed As Date: parsed = ParseSafeDate(testVal)
                                        If parsed > DateSerial(2000, 1, 1) And parsed < DateSerial(2100, 1, 1) Then dateCount = dateCount + 1
                                        If nonBlankCount >= 5 Then Exit For
                                    End If
                                Next checkRow
                                If nonBlankCount > 0 And dateCount = 0 Then GoTo NextAlias
                            End If
                            FindSmartHeaderCol = c
                            Exit Function
                        End If
NextAlias:
                    Next i
                End If
            End If
        Next c
    Next r
    FindSmartHeaderCol = 0
End Function

Function GetOriginRegion(countryCode As String, postCode As String, dictOrigRegs As Object) As String
    Dim pcPrefix As Integer: pcPrefix = -1
    Dim clnPost As String: clnPost = Trim(postCode)
    If Len(clnPost) >= 2 Then
        If IsNumeric(Left(clnPost, 2)) Then pcPrefix = CInt(Left(clnPost, 2))
    End If
    Dim derivedOrig As String: derivedOrig = ""
    If dictOrigRegs.exists(UCase(Trim(countryCode))) Then
        Dim colRegs As Collection: Set colRegs = dictOrigRegs(UCase(Trim(countryCode)))
        If colRegs.Count = 1 Then
            GetOriginRegion = CStr(colRegs(1))
            Exit Function
        End If
        Dim vReg As Variant, regStr As String, insideP As String, bounds() As String
        For Each vReg In colRegs
            regStr = CStr(vReg)
            If InStr(regStr, "(") > 0 And InStr(regStr, ")") > 0 Then
                insideP = Mid(regStr, InStr(regStr, "(") + 1, InStr(regStr, ")") - InStr(regStr, "(") - 1)
                If InStr(insideP, "-") > 0 Then
                    bounds = Split(insideP, "-")
                    If IsNumeric(Trim(bounds(0))) And IsNumeric(Trim(bounds(1))) Then
                        If pcPrefix >= CInt(Trim(bounds(0))) And pcPrefix <= CInt(Trim(bounds(1))) Then
                            derivedOrig = regStr: Exit For
                        End If
                    End If
                ElseIf IsNumeric(Trim(insideP)) Then
                    If pcPrefix = CInt(Trim(insideP)) Then derivedOrig = regStr: Exit For
                End If
            End If
        Next vReg
        If derivedOrig = "" Then
            For Each vReg In colRegs
                regStr = CStr(vReg)
                If InStr(regStr, "(") = 0 Then derivedOrig = regStr: Exit For
            Next vReg
        End If
        If derivedOrig = "" And colRegs.Count > 0 Then derivedOrig = CStr(colRegs(1))
    End If
    If derivedOrig = "" Then derivedOrig = "Unmapped Origin"
    GetOriginRegion = derivedOrig
End Function

Function GetSafeArrayVal(arr As Variant, rowIdx As Long, colIdx As Long) As Variant
    If colIdx > 0 And colIdx <= UBound(arr, 2) Then GetSafeArrayVal = arr(rowIdx, colIdx) Else GetSafeArrayVal = Empty
End Function

Function ParseSafeDate(ByVal val As Variant) As Date
    If IsEmpty(val) Or val = "" Then ParseSafeDate = 0: Exit Function
    If VarType(val) = vbDate Or VarType(val) = vbDouble Then ParseSafeDate = Int(CDbl(val)): Exit Function
    Dim sVal As String, dPart As String, strArr() As String, parts() As String
    sVal = Replace(Trim(CStr(val)), Chr(160), " ")
    strArr = Split(sVal, " "): dPart = strArr(0)
    parts = Split(dPart, "/")
    If UBound(parts) = 0 Then parts = Split(dPart, "-")
    If UBound(parts) = 2 Then
        If IsNumeric(parts(0)) And IsNumeric(parts(1)) And IsNumeric(parts(2)) Then
            Dim p0 As Integer, p1 As Integer, p2 As Integer
            p0 = CInt(parts(0)): p1 = CInt(parts(1)): p2 = CInt(parts(2))
            If p2 < 100 Then p2 = p2 + 2000
            If p0 > 12 And p1 <= 12 Then ParseSafeDate = DateSerial(p2, p1, p0): Exit Function
            If p1 > 12 And p0 <= 12 Then ParseSafeDate = DateSerial(p2, p0, p1): Exit Function
        End If
    End If
    On Error Resume Next
    ParseSafeDate = Int(CDbl(CDate(dPart)))
    If Err.Number <> 0 Then ParseSafeDate = Int(CDbl(CDate(val)))
    On Error GoTo 0
End Function

Function CleanSvc(ByVal svc As String) As String
    Dim s As String
    s = UCase(Trim(svc))
    s = Replace(s, "SERVICE", "")
    s = Replace(s, "LEVEL", "")
    s = Replace(s, " ", "")
    CleanSvc = s
End Function

