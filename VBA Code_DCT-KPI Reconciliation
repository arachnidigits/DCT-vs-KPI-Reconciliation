    ' 11. Dashboard Tab Creation (NEW)
    ' ==========================================
    Set wsDashboard = wbOut.Sheets.Add(After:=wsOutput)
    wsDashboard.Name = "Delay Dashboard"
    wsDashboard.Cells.Font.Color = vbBlack
    wsDashboard.Activate
    ActiveWindow.DisplayGridlines = False
    
    wsDashboard.Range("A1").Value = "Delay Discrepancy Dashboard"
    wsDashboard.Range("A1").Font.Size = 16
    wsDashboard.Range("A1").Font.Bold = True

    ' ==========================================
    ' 12. Delays Tab Creation & Formatting
    ' ==========================================
    Set wsDelayTab = wbOut.Sheets.Add(After:=wsDashboard)
    wsDelayTab.Name = "Delay Data"
    wsDelayTab.Cells.Font.Color = vbBlack
    
    ' Hidden Toggle states
    wsDelayTab.Range("R1").Value = True ' SC Discrepancy
    wsDelayTab.Range("S1").Value = True ' POD Discrepancy
    wsDelayTab.Range("T1").Value = True ' KPI Delay Only
    
    ' Buttons will be instantiated but coordinates shifted dynamically below table
    Dim shpKPI As Shape
    Set shpKPI = wsDelayTab.Shapes.AddShape(msoShapeRoundedRectangle, 0, 0, 210, 25)
    shpKPI.Name = "btnKPI"
