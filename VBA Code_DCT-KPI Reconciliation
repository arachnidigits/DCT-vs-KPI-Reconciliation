Option Explicit

Sub CompareShipmentData()
    Dim wsOutput As Worksheet, wsDelayTab As Worksheet, wsDashboard As Worksheet
    Dim wbDCT As Workbook, wbKPI As Workbook, wbRateCard As Workbook
    Dim dctFilePath As String, kpiFilePath As String, rcFilePath As String
    Dim targetMonth As Integer, targetYear As Integer
    Dim userInput As String
    
    ' 1. Prompt for Target Month and Year
    userInput = InputBox("Enter the target month and year for validation (MM/YYYY):", "Select Target Month", Format(Date, "mm/yyyy"))
    If userInput = "" Then Exit Sub
    
    ' Fix: Manually parse the input to bypass Windows OS Regional Date bugs
    userInput = Replace(userInput, "-", "/")
    Dim userParts() As String
    userParts = Split(userInput, "/")
    
    If UBound(userParts) = 1 Then
        If IsNumeric(userParts(0)) And IsNumeric(userParts(1)) Then
            targetMonth = CInt(userParts(0))
            targetYear = CInt(userParts(1))
        Else
            MsgBox "Invalid date format. Please use numerical MM/YYYY.", vbCritical
            Exit Sub
        End If
    Else
        MsgBox "Invalid date format. Please use MM/YYYY.", vbCritical
        Exit Sub
    End If
    
    ' 2. Prompt for DCT, KPI, and Rate Card Files
    MsgBox "Please select the DCT Data File (API).", vbInformation
    dctFilePath = Application.GetOpenFilename("Excel Files (*.xls*), *.xls*", , "Select DCT Data File")
    If dctFilePath = "False" Then Exit Sub
    
    MsgBox "Please select the LSP KPI Report File.", vbInformation
    kpiFilePath = Application.GetOpenFilename("Excel Files (*.xls*), *.xls*", , "Select LSP KPI Report File")
    If kpiFilePath = "False" Then Exit Sub
    
    MsgBox "Please select the Rate Card File.", vbInformation, "Select Rate Card"
    rcFilePath = Application.GetOpenFilename("Excel Files (*.xls*), *.xls*", , "Select Rate Card File")
    If rcFilePath = "False" Then Exit Sub
    
    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    
    ' ==========================================
    ' 3. SYSTEM-GENERATED FILE WORKAROUND & LOAD
    ' ==========================================
    Application.DisplayAlerts = False ' Suppress file format warnings
    
    ' Open DCT File
    Set wbDCT = OpenWorkbookSafely(dctFilePath)
    If wbDCT Is Nothing Then
        MsgBox "Error: The DCT file could not be loaded into memory.", vbCritical
        GoTo ExitMacro
    End If
    
    ' Open KPI File
    Set wbKPI = OpenWorkbookSafely(kpiFilePath)
    If wbKPI Is Nothing Then
        MsgBox "Error: The KPI file could not be loaded into memory.", vbCritical
        wbDCT.Close False
        GoTo ExitMacro
    End If
    
    ' Open Rate Card File
    Set wbRateCard = OpenWorkbookSafely(rcFilePath)
    If wbRateCard Is Nothing Then
        MsgBox "Error: The Rate Card file could not be loaded into memory.", vbCritical
        wbDCT.Close False: wbKPI.Close False
        GoTo ExitMacro
    End If
    
    Application.DisplayAlerts = True ' Turn alerts back on
    
    ' ==========================================
    ' 4. LOAD RATE CARD & MAPPINGS
    ' ==========================================
    Dim wsRC As Worksheet, wsDestMap As Worksheet, wsCountryMap As Worksheet
    Set wsRC = wbRateCard.Sheets(1)
    
    On Error Resume Next
    Set wsDestMap = wbRateCard.Sheets("Destination Mapping")
    Set wsCountryMap = wbRateCard.Sheets("Country Code Mapping")
    On Error GoTo 0
    
    If wsDestMap Is Nothing Or wsCountryMap Is Nothing Then
        MsgBox "Error: Mapping sheets not found in the Rate Card.", vbCritical
        wbDCT.Close False: wbKPI.Close False: wbRateCard.Close False
        GoTo ExitMacro
    End If
    
    ' Dictionary: Destination Mapping
    Dim dictDestMap As Object
    Set dictDestMap = CreateObject("Scripting.Dictionary")
    dictDestMap.CompareMode = vbTextCompare
    
    Dim lrDest As Long, r As Long, arrDest As Variant
    lrDest = wsDestMap.Cells(wsDestMap.Rows.Count, "A").End(xlUp).Row
    If lrDest >= 2 Then
        arrDest = wsDestMap.Range("A2:B" & lrDest).Value2
        For r = 1 To UBound(arrDest, 1)
            If Trim(CStr(arrDest(r, 1))) <> "" Then
                dictDestMap(LCase(Trim(CStr(arrDest(r, 1))))) = Trim(CStr(arrDest(r, 2)))
            End If
        Next r
    End If
    
    ' Dictionary: Country Code Mapping
    Dim dictCountryMap As Object
    Set dictCountryMap = CreateObject("Scripting.Dictionary")
    dictCountryMap.CompareMode = vbTextCompare
    
    Dim lrCountry As Long, arrCountry As Variant
    lrCountry = wsCountryMap.Cells(wsCountryMap.Rows.Count, "A").End(xlUp).Row
    If lrCountry >= 2 Then
        arrCountry = wsCountryMap.Range("A2:B" & lrCountry).Value2
        For r = 1 To UBound(arrCountry, 1)
            If Trim(CStr(arrCountry(r, 1))) <> "" Then
                dictCountryMap(LCase(Trim(CStr(arrCountry(r, 1))))) = Trim(CStr(arrCountry(r, 2)))
            End If
        Next r
    End If
    
    ' Dictionaries: Rate Card and Origin Regions
    Dim dictRateCard As Object, dictOrigRegs As Object
    Set dictRateCard = CreateObject("Scripting.Dictionary")
    Set dictOrigRegs = CreateObject("Scripting.Dictionary")
    dictRateCard.CompareMode = vbTextCompare
    dictOrigRegs.CompareMode = vbTextCompare
    
    Dim c_rcCountry As Long, c_rcOrigReg As Long, c_rcDestReg As Long, c_rcSvc As Long, c_rcDays As Long
    c_rcCountry = FindExactHeaderCol(wsRC, "1 Origin Country [ISO country code]", 3)
    c_rcOrigReg = FindExactHeaderCol(wsRC, "2 Place/Zone of Origin", 3)
    c_rcDestReg = FindExactHeaderCol(wsRC, "8 Place/Zone of Destination", 3)
    c_rcSvc = FindExactHeaderCol(wsRC, "9 Type of service", 3)
    c_rcDays = FindExactHeaderCol(wsRC, "36.1 Total Transit Time Door-Door [days]", 3)
    
    Dim lrRC As Long
    lrRC = wsRC.Cells(wsRC.Rows.Count, c_rcCountry).End(xlUp).Row
    Dim rcCountry As String, rcOrig As String, rcDest As String, rcSvc As String, rcDays As Variant
    Dim laneKey As String
    
    For r = 2 To lrRC
        rcCountry = Trim(CStr(wsRC.Cells(r, c_rcCountry).Value2))
        rcOrig = Trim(CStr(wsRC.Cells(r, c_rcOrigReg).Value2))
        rcDest = Trim(CStr(wsRC.Cells(r, c_rcDestReg).Value2))
        rcSvc = Trim(CStr(wsRC.Cells(r, c_rcSvc).Value2))
        rcDays = wsRC.Cells(r, c_rcDays).Value2
        
        If rcCountry <> "" And rcOrig <> "" Then
            If Not dictOrigRegs.exists(rcCountry) Then dictOrigRegs.Add rcCountry, New Collection
            Dim col As Collection, v As Variant, exists As Boolean
            Set col = dictOrigRegs(rcCountry): exists = False
            For Each v In col
                If CStr(v) = rcOrig Then exists = True: Exit For
            Next v
            If Not exists Then col.Add rcOrig
            
            laneKey = UCase(rcCountry) & "|" & UCase(rcOrig) & "|" & UCase(rcDest) & "|" & CleanSvc(rcSvc)
            dictRateCard(laneKey) = rcDays
        End If
    Next r
    wbRateCard.Close False

    ' ==========================================
    ' 5. PREP DCT & KPI DATA
    ' ==========================================
    Dim wsDCT As Worksheet
    Set wsDCT = wbDCT.Sheets(1)
    
    Dim lastRowDCT As Long
    lastRowDCT = wsDCT.Cells(wsDCT.Rows.Count, "B").End(xlUp).Row
    If lastRowDCT < 2 Then
        MsgBox "Error: The DCT Data file appears to be empty.", vbCritical
        wbDCT.Close False: wbKPI.Close False
        GoTo ExitMacro
    End If
    
    Dim arrDCT As Variant
    arrDCT = wsDCT.Range(wsDCT.Cells(1, 1), wsDCT.Cells(lastRowDCT, 150)).Value2
    
    Dim wsKPI As Worksheet, wsDelayCodes As Worksheet
    Dim ws As Worksheet
    For Each ws In wbKPI.Sheets
        If UCase(Trim(ws.Name)) Like "*A) WORKSHEET*" Then Set wsKPI = ws
        If UCase(Trim(ws.Name)) Like "*DELAY CODES*" Then Set wsDelayCodes = ws
    Next ws
    
    If wsKPI Is Nothing Then
        MsgBox "Sheet 'A) Worksheet' could not be found in the KPI Report.", vbCritical
        wbDCT.Close False: wbKPI.Close False
        GoTo ExitMacro
    End If
    
    Dim lastRowKPI As Long
    lastRowKPI = wsKPI.Cells(wsKPI.Rows.Count, "B").End(xlUp).Row
    If lastRowKPI < 6 Then
        MsgBox "Error: The KPI report appears to be empty.", vbCritical
        wbDCT.Close False: wbKPI.Close False
        GoTo ExitMacro
    End If
    
    Dim arrKPI As Variant
    arrKPI = wsKPI.Range(wsKPI.Cells(1, 1), wsKPI.Cells(lastRowKPI, 150)).Value2
    
    ' ==============================================================
    ' 6. FULLY DYNAMIC HYBRID COLUMN MAPPING
    ' ==============================================================
    Dim c_dctHAWB As Long, c_dctPOD As Long, c_dctSVC As Long, c_dctAPD As Long
    Dim c_dctSC As Long, c_dctATD As Long, c_dctATA As Long, c_dctTransit As Long, c_dctHOB As Long
    
    Dim c_kpiHAWB As Long, c_kpiPOD As Long, c_kpiSVC As Long, c_kpiAPD As Long
    Dim c_kpiSC As Long, c_kpiATD As Long, c_kpiATA As Long, c_kpiTransit As Long, c_kpiDCode As Long
    Dim c_kpiCountry As Long, c_kpiPostCode As Long, c_kpiDestCity As Long, c_kpiOnTime As Long, c_kpiHOB As Long
    
    ' MAP DCT COLUMNS
    c_dctHAWB = FindSmartHeaderCol(wsDCT, "HAWB", 2, False)
    c_dctSVC = FindSmartHeaderCol(wsDCT, "SVC", 2, False)
    c_dctAPD = FindSmartHeaderCol(wsDCT, "APD", 2, True)
    c_dctSC = FindExactHeaderCol(wsDCT, "Start Clock", 2)
    If c_dctSC = 0 Then c_dctSC = FindSmartHeaderCol(wsDCT, "SC", 2, True) ' Fallback
    c_dctATD = FindSmartHeaderCol(wsDCT, "ATD", 2, True)
    c_dctATA = FindSmartHeaderCol(wsDCT, "ATA", 2, True)
    c_dctPOD = FindSmartHeaderCol(wsDCT, "POD", 2, True)
    c_dctTransit = FindSmartHeaderCol(wsDCT, "TRANSIT", 2, False)
    c_dctHOB = FindExactHeaderCol(wsDCT, "Handover to Broker Date", 2) ' NEW HOB COLUMN
    
    ' MAP KPI COLUMNS
    c_kpiHAWB = FindSmartHeaderCol(wsKPI, "HAWB", 6, False)
    c_kpiSVC = FindSmartHeaderCol(wsKPI, "SVC", 6, False)
    c_kpiAPD = FindSmartHeaderCol(wsKPI, "APD", 6, True)
    c_kpiSC = FindExactHeaderCol(wsKPI, "Start Clock", 6)
    If c_kpiSC = 0 Then c_kpiSC = FindSmartHeaderCol(wsKPI, "SC", 6, True) ' Fallback
    c_kpiATD = FindSmartHeaderCol(wsKPI, "ATD", 6, True)
    c_kpiATA = FindSmartHeaderCol(wsKPI, "ATA", 6, True)
    c_kpiPOD = FindSmartHeaderCol(wsKPI, "POD", 6, True)
    c_kpiTransit = FindSmartHeaderCol(wsKPI, "TRANSIT", 6, False)
    c_kpiDCode = FindSmartHeaderCol(wsKPI, "DELAY", 6, False)
    c_kpiOnTime = FindExactHeaderCol(wsKPI, "Shipment On Time", 6)
    c_kpiHOB = FindExactHeaderCol(wsKPI, "Handover to Brooker", 6)
    If c_kpiHOB = 0 Then c_kpiHOB = FindExactHeaderCol(wsKPI, "Handover to Broker", 6)
    
    ' MAP RATE CARD KPI COLUMNS
    c_kpiCountry = FindExactHeaderCol(wsKPI, "Origin Country", 6)
    c_kpiPostCode = FindExactHeaderCol(wsKPI, "Origin Post Code", 6)
    c_kpiDestCity = FindExactHeaderCol(wsKPI, "Destination City", 6)
    
    If c_dctHAWB = 0 Or c_kpiHAWB = 0 Or c_dctPOD = 0 Or c_kpiPOD = 0 Then
        MsgBox "Critical Error: Could not dynamically locate the HAWB or POD columns.", vbCritical
        wbDCT.Close False: wbKPI.Close False
        GoTo ExitMacro
    End If
    
    Dim dictAPI As Object, dictKPI As Object
    Set dictAPI = CreateObject("Scripting.Dictionary"): dictAPI.CompareMode = vbTextCompare
    Set dictKPI = CreateObject("Scripting.Dictionary"): dictKPI.CompareMode = vbTextCompare
    
    Dim dictSeenCodes As Object
    Set dictSeenCodes = CreateObject("Scripting.Dictionary"): dictSeenCodes.CompareMode = vbTextCompare
    
    ' ==============================================================
    ' 6b. DYNAMIC DELAY CODES, REASON & ACCOUNTABLE MAPPING
    ' ==============================================================
    Dim dictDelayCodes As Object
    Set dictDelayCodes = CreateObject("Scripting.Dictionary"): dictDelayCodes.CompareMode = vbTextCompare
    
    If Not wsDelayCodes Is Nothing Then
        Dim headerRowMap As Long, rMap As Long, cMap As Long
        Dim c_mapDelayCode As Long, c_mapReason As Long, c_mapAcc As Long, c_mapStatus As Long
        
        headerRowMap = 1
        For rMap = 1 To 15
            For cMap = 1 To 20
                Dim cellValMap As String
                cellValMap = UCase(Trim(CStr(wsDelayCodes.Cells(rMap, cMap).Value)))
                If cellValMap = "CODE" Or cellValMap Like "*DELAY CODE*" Or cellValMap Like "FOLLOW-UP WITH*" Then
                    headerRowMap = rMap
                    Exit For
                End If
            Next cMap
            If headerRowMap > 1 Then Exit For
        Next rMap
        
        For cMap = 1 To 30
            cellValMap = UCase(Trim(CStr(wsDelayCodes.Cells(headerRowMap, cMap).Value)))
            If cellValMap Like "*DELAY CODE*" Or cellValMap = "EXCEPTION CODE" Then c_mapDelayCode = cMap
            If cellValMap = "CODE" Then c_mapReason = cMap
            If cellValMap Like "FOLLOW-UP WITH*" Or cellValMap Like "FOLLOW UP WITH*" Then c_mapAcc = cMap
            If cellValMap Like "*CHARGEAB*" Or cellValMap = "STATUS" Then c_mapStatus = cMap
        Next cMap
        
        If c_mapDelayCode = 0 Then c_mapDelayCode = 1
        If c_mapStatus = 0 Then c_mapStatus = 4
        
        Dim lastRowDelayMap As Long, d As Long
        lastRowDelayMap = wsDelayCodes.Cells(wsDelayCodes.Rows.Count, c_mapDelayCode).End(xlUp).Row
        
        If lastRowDelayMap > headerRowMap Then
            For d = headerRowMap + 1 To lastRowDelayMap
                Dim dKey As String
                dKey = Trim(CStr(wsDelayCodes.Cells(d, c_mapDelayCode).Value))
                If dKey <> "" Then
                    Dim vStatus As String, vReason As String, vAcc As String
                    If c_mapStatus > 0 Then vStatus = Trim(CStr(wsDelayCodes.Cells(d, c_mapStatus).Value)) Else vStatus = "N/A"
                    If c_mapReason > 0 Then vReason = Trim(CStr(wsDelayCodes.Cells(d, c_mapReason).Value)) Else vReason = "N/A"
                    If c_mapAcc > 0 Then vAcc = Trim(CStr(wsDelayCodes.Cells(d, c_mapAcc).Value)) Else vAcc = "N/A"
                    
                    dictDelayCodes(dKey) = Array(vStatus, vReason, vAcc)
                End If
            Next d
        End If
    End If
    
    Dim i As Long
    Dim podDate As Date, filterDate As Date, tempSC As Date, tempAPD As Date, tempATD As Date, tempATA As Date
    Dim tempHOB As Date
    Dim hawb As String, svc As String, apd As Variant, sc As Variant, atd As Variant, ata As Variant
    Dim transitTime As Long, dCode As String
    Dim apiCount As Long, kpiCount As Long
    apiCount = 0: kpiCount = 0
    
    ' 7. Process DCT (API) Data
    For i = 2 To UBound(arrDCT, 1)
        hawb = Trim(CStr(GetSafeArrayVal(arrDCT, i, c_dctHAWB)))
        If hawb <> "" Then
            podDate = ParseSafeDate(GetSafeArrayVal(arrDCT, i, c_dctPOD))
            tempHOB = 0
            If c_dctHOB > 0 Then tempHOB = ParseSafeDate(GetSafeArrayVal(arrDCT, i, c_dctHOB))
            
            filterDate = podDate
            If filterDate = 0 And tempHOB > 0 Then filterDate = tempHOB
            
            If filterDate > 0 And Month(filterDate) = targetMonth And Year(filterDate) = targetYear Then
                apiCount = apiCount + 1
                svc = Trim(CStr(GetSafeArrayVal(arrDCT, i, c_dctSVC)))
                tempAPD = ParseSafeDate(GetSafeArrayVal(arrDCT, i, c_dctAPD))
                If tempAPD > 0 Then apd = tempAPD Else apd = ""
                tempSC = ParseSafeDate(GetSafeArrayVal(arrDCT, i, c_dctSC))
                If tempSC > 0 Then sc = tempSC Else sc = ""
                tempATD = ParseSafeDate(GetSafeArrayVal(arrDCT, i, c_dctATD))
                If tempATD > 0 Then atd = tempATD Else atd = ""
                tempATA = ParseSafeDate(GetSafeArrayVal(arrDCT, i, c_dctATA))
                If tempATA > 0 Then ata = tempATA Else ata = ""
                
                transitTime = 0
                Dim ttVal As Variant
                ttVal = GetSafeArrayVal(arrDCT, i, c_dctTransit)
                If IsNumeric(ttVal) And Not IsEmpty(ttVal) Then transitTime = CLng(ttVal)
                
                dictAPI(hawb) = Array(svc, apd, sc, podDate, transitTime, tempSC, atd, ata, tempHOB)
            End If
        End If
    Next i
    
    ' 8. Process KPI Data
    Dim kCountry As String, kPost As String, kCity As String, kOnTime As String
    
    For i = 6 To UBound(arrKPI, 1)
        hawb = Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiHAWB)))
        If hawb <> "" Then
            podDate = ParseSafeDate(GetSafeArrayVal(arrKPI, i, c_kpiPOD))
            tempHOB = 0
            If c_kpiHOB > 0 Then tempHOB = ParseSafeDate(GetSafeArrayVal(arrKPI, i, c_kpiHOB))
            
            filterDate = podDate
            If filterDate = 0 And tempHOB > 0 Then filterDate = tempHOB
            
            If filterDate > 0 And Month(filterDate) = targetMonth And Year(filterDate) = targetYear Then
                kpiCount = kpiCount + 1
                svc = Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiSVC)))
                tempAPD = ParseSafeDate(GetSafeArrayVal(arrKPI, i, c_kpiAPD))
                If tempAPD > 0 Then apd = tempAPD Else apd = ""
                tempSC = ParseSafeDate(GetSafeArrayVal(arrKPI, i, c_kpiSC))
                If tempSC > 0 Then sc = tempSC Else sc = ""
                tempATD = ParseSafeDate(GetSafeArrayVal(arrKPI, i, c_kpiATD))
                If tempATD > 0 Then atd = tempATD Else atd = ""
                tempATA = ParseSafeDate(GetSafeArrayVal(arrKPI, i, c_kpiATA))
                If tempATA > 0 Then ata = tempATA Else ata = ""
                
                transitTime = 0
                ttVal = GetSafeArrayVal(arrKPI, i, c_kpiTransit)
                If IsNumeric(ttVal) And Not IsEmpty(ttVal) Then transitTime = CLng(ttVal)
                
                dCode = ""
                If Not IsError(GetSafeArrayVal(arrKPI, i, c_kpiDCode)) Then dCode = Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiDCode)))
                
                kCountry = "": kPost = "": kCity = "": kOnTime = ""
                If c_kpiCountry > 0 Then kCountry = Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiCountry)))
                If c_kpiPostCode > 0 Then
                    kPost = Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiPostCode)))
                    kPost = Replace(kPost, " ", "")
                End If
                If c_kpiDestCity > 0 Then kCity = Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiDestCity)))
                If c_kpiOnTime > 0 Then kOnTime = UCase(Trim(CStr(GetSafeArrayVal(arrKPI, i, c_kpiOnTime))))
                
                dictKPI(hawb) = Array(svc, apd, sc, podDate, transitTime, dCode, tempSC, atd, ata, kCountry, kPost, kCity, kOnTime, tempHOB)
            End If
        End If
    Next i
    
    wbDCT.Close False: wbKPI.Close False
    
    If kpiCount = 0 Then
        Application.ScreenUpdating = True
        Application.Calculation = xlCalculationAutomatic
        MsgBox "Error: The KPI report contains no valid dates for " & userInput & ".", vbExclamation, "Data Parsing Error"
        Exit Sub
    End If
    
    ' 9. Compare and Compile Output
    Dim outMissing() As Variant, outSvc() As Variant, outSC() As Variant, outDelay() As Variant
    Dim outAPD() As Variant, outATD() As Variant, outATA() As Variant, outPOD() As Variant
    
    ReDim outMissing(1 To WorksheetFunction.Max(dictAPI.Count, dictKPI.Count) + 1, 1 To 2)
    ReDim outSvc(1 To dictAPI.Count + 1, 1 To 4)
    ReDim outSC(1 To dictAPI.Count + 1, 1 To 4)
    ReDim outDelay(1 To dictAPI.Count + 1, 1 To 16)
    ReDim outAPD(1 To dictAPI.Count + 1, 1 To 4)
    ReDim outATD(1 To dictAPI.Count + 1, 1 To 4)
    ReDim outATA(1 To dictAPI.Count + 1, 1 To 4)
    ReDim outPOD(1 To dictAPI.Count + 1, 1 To 4)
    
    Dim mRow As Long, sRow As Long, cRow As Long, dRow As Long
    Dim aRow As Long, tRow As Long, rRow As Long, pRow As Long
    mRow = 1: sRow = 1: cRow = 1: dRow = 1: aRow = 1: tRow = 1: rRow = 1: pRow = 1
    
    Dim key As Variant, apiVals As Variant, kpiVals As Variant
    Dim apiSvc As String, kpiSvc As String
    Dim apiAPD As Variant, kpiAPD As Variant, apiSC As Variant, kpiSC As Variant
    Dim apiATD As Variant, kpiATD As Variant, apiATA As Variant, kpiATA As Variant
    Dim apiPODDate As Date, kpiPODDate As Date, kpiDCode As String
    Dim apiHOBDate As Date, kpiHOBDate As Date
    Dim apiSCDate As Date
    Dim isApiDelay As Boolean, isKpiDelay As Boolean
    Dim apiCompareDate As Date, kpiCompareDate As Date
    Dim apiDateType As String, kpiDateType As String
    
    For Each key In dictAPI.Keys
        apiVals = dictAPI(key)
        apiSvc = apiVals(0): apiAPD = apiVals(1): apiSC = apiVals(2)
        apiPODDate = apiVals(3): apiSCDate = apiVals(5)
        apiATD = apiVals(6): apiATA = apiVals(7)
        apiHOBDate = apiVals(8)
        
        If apiPODDate > 0 Then
            apiCompareDate = apiPODDate: apiDateType = "POD"
        ElseIf apiHOBDate > 0 Then
            apiCompareDate = apiHOBDate: apiDateType = "HOB"
        Else
            apiCompareDate = 0: apiDateType = "Missing"
        End If
        
        If Not dictKPI.exists(key) Then
            outMissing(mRow, 1) = key
            mRow = mRow + 1
        Else
            kpiVals = dictKPI(key)
            kpiSvc = kpiVals(0): kpiAPD = kpiVals(1): kpiSC = kpiVals(2)
            kpiPODDate = kpiVals(3): kpiDCode = kpiVals(5)
            kpiATD = kpiVals(7): kpiATA = kpiVals(8)
            
            Dim kCountryName As String, kPostName As String, kCityName As String, kOnTimeFlag As String
            kCountryName = kpiVals(9): kPostName = kpiVals(10): kCityName = kpiVals(11): kOnTimeFlag = kpiVals(12)
            kpiHOBDate = kpiVals(13)
            
            If kpiPODDate > 0 Then
                kpiCompareDate = kpiPODDate: kpiDateType = "POD"
            ElseIf kpiHOBDate > 0 Then
                kpiCompareDate = kpiHOBDate: kpiDateType = "HOB"
            Else
                kpiCompareDate = 0: kpiDateType = "Missing"
            End If
            
            Dim cleanApiSvc As String, cleanKpiSvc As String
            cleanApiSvc = CleanSvc(apiSvc)
            cleanKpiSvc = CleanSvc(kpiSvc)
            
            If cleanApiSvc <> cleanKpiSvc Then
                outSvc(sRow, 1) = key
                outSvc(sRow, 2) = Trim(Replace(apiSvc, "Service", "", 1, -1, vbTextCompare))
                outSvc(sRow, 3) = Trim(Replace(kpiSvc, "Service", "", 1, -1, vbTextCompare))
                outSvc(sRow, 4) = "Mismatch"
                sRow = sRow + 1
            End If
            
            If apiAPD = "" And kpiAPD <> "" Then
                outAPD(aRow, 1) = key: outAPD(aRow, 2) = apiAPD: outAPD(aRow, 3) = kpiAPD: outAPD(aRow, 4) = "Missing in API": aRow = aRow + 1
            ElseIf apiAPD <> "" And kpiAPD = "" Then
                outAPD(aRow, 1) = key: outAPD(aRow, 2) = apiAPD: outAPD(aRow, 3) = kpiAPD: outAPD(aRow, 4) = "Missing in KPI": aRow = aRow + 1
            ElseIf apiAPD <> "" And kpiAPD <> "" Then
                If Abs(apiAPD - kpiAPD) >= 3 Then outAPD(aRow, 1) = key: outAPD(aRow, 2) = apiAPD: outAPD(aRow, 3) = kpiAPD: outAPD(aRow, 4) = "Mismatch": aRow = aRow + 1
            End If
            
            If apiATD = "" And kpiATD <> "" Then
                outATD(tRow, 1) = key: outATD(tRow, 2) = apiATD: outATD(tRow, 3) = kpiATD: outATD(tRow, 4) = "Missing in API": tRow = tRow + 1
            ElseIf apiATD <> "" And kpiATD = "" Then
                outATD(tRow, 1) = key: outATD(tRow, 2) = apiATD: outATD(tRow, 3) = kpiATD: outATD(tRow, 4) = "Missing in KPI": tRow = tRow + 1
            ElseIf apiATD <> "" And kpiATD <> "" Then
                If Abs(apiATD - kpiATD) >= 3 Then outATD(tRow, 1) = key: outATD(tRow, 2) = apiATD: outATD(tRow, 3) = kpiATD: outATD(tRow, 4) = "Mismatch": tRow = tRow + 1
            End If
            
            If apiATA = "" And kpiATA <> "" Then
                outATA(rRow, 1) = key: outATA(rRow, 2) = apiATA: outATA(rRow, 3) = kpiATA: outATA(rRow, 4) = "Missing in API": rRow = rRow + 1
            ElseIf apiATA <> "" And kpiATA = "" Then
                outATA(rRow, 1) = key: outATA(rRow, 2) = apiATA: outATA(rRow, 3) = kpiATA: outATA(rRow, 4) = "Missing in KPI": rRow = rRow + 1
            ElseIf apiATA <> "" And kpiATA <> "" Then
                If Abs(apiATA - kpiATA) >= 3 Then outATA(rRow, 1) = key: outATA(rRow, 2) = apiATA: outATA(rRow, 3) = kpiATA: outATA(rRow, 4) = "Mismatch": rRow = rRow + 1
            End If
            
            Dim hasPODDisc As Boolean: hasPODDisc = False
            
            If apiCompareDate = 0 And kpiCompareDate > 0 Then
                outPOD(pRow, 1) = key: outPOD(pRow, 2) = "Missing": outPOD(pRow, 3) = kpiCompareDate: outPOD(pRow, 4) = "Missing in API": pRow = pRow + 1
                hasPODDisc = True
            ElseIf apiCompareDate > 0 And kpiCompareDate = 0 Then
                outPOD(pRow, 1) = key: outPOD(pRow, 2) = apiCompareDate: outPOD(pRow, 3) = "Missing": outPOD(pRow, 4) = "Missing in KPI": pRow = pRow + 1
                hasPODDisc = True
            ElseIf apiCompareDate > 0 And kpiCompareDate > 0 Then
                If Abs(apiCompareDate - kpiCompareDate) >= 3 Then
                    outPOD(pRow, 1) = key: outPOD(pRow, 2) = apiCompareDate: outPOD(pRow, 3) = kpiCompareDate
                    If apiDateType <> kpiDateType Then
                        outPOD(pRow, 4) = "Mismatch (" & apiDateType & " vs " & kpiDateType & ")"
                    Else
                        outPOD(pRow, 4) = "Mismatch"
                    End If
                    pRow = pRow + 1
                    hasPODDisc = True
                End If
            End If
            
            Dim hasSCDisc As Boolean: hasSCDisc = False
            If apiSC = "" And kpiSC <> "" Then
                outSC(cRow, 1) = key: outSC(cRow, 2) = apiSC: outSC(cRow, 3) = kpiSC: outSC(cRow, 4) = "Missing in API": cRow = cRow + 1
                hasSCDisc = True
            ElseIf apiSC <> "" And kpiSC = "" Then
                outSC(cRow, 1) = key: outSC(cRow, 2) = apiSC: outSC(cRow, 3) = kpiSC: outSC(cRow, 4) = "Missing in KPI": cRow = cRow + 1
                hasSCDisc = True
            ElseIf apiSC <> "" And kpiSC <> "" Then
                If Abs(apiSC - kpiSC) >= 3 Then
                    outSC(cRow, 1) = key: outSC(cRow, 2) = apiSC: outSC(cRow, 3) = kpiSC: outSC(cRow, 4) = "Mismatch": cRow = cRow + 1
                    hasSCDisc = True
                End If
            End If
            
            Dim derivedCountryCode As String, derivedDest As String, derivedOrig As String
            
            If Len(kCountryName) = 2 Then
                derivedCountryCode = UCase(kCountryName)
            ElseIf dictCountryMap.exists(LCase(kCountryName)) Then
                derivedCountryCode = dictCountryMap(LCase(kCountryName))
            Else
                derivedCountryCode = "Unmapped Country"
            End If
            
            derivedDest = "Unmapped City"
            If dictDestMap.exists(LCase(kCityName)) Then derivedDest = dictDestMap(LCase(kCityName))
            
            derivedOrig = GetOriginRegion(derivedCountryCode, kPostName, dictOrigRegs)
            laneKey = UCase(derivedCountryCode) & "|" & UCase(derivedOrig) & "|" & UCase(derivedDest) & "|" & CleanSvc(kpiSvc)
            
            Dim contractedDays As Variant, contractedDate As Variant
            contractedDate = Empty
            
            If dictRateCard.exists(laneKey) Then
                contractedDays = dictRateCard(laneKey)
                If IsNumeric(contractedDays) And apiSCDate > 0 Then
                    contractedDate = DateAdd("d", contractedDays, apiSCDate)
                End If
            Else
                contractedDays = "Lane Not Available"
            End If
            
            isApiDelay = False: isKpiDelay = False
            If Not IsEmpty(contractedDate) Then
                If apiCompareDate > contractedDate Then isApiDelay = True
            End If
            If kOnTimeFlag = "N" Then isKpiDelay = True
            
            Dim scenario As String: scenario = ""
            If contractedDays = "Lane Not Available" Or derivedCountryCode = "Unmapped Country" Or derivedDest = "Unmapped City" Or derivedOrig = "Unmapped Origin" Then
                scenario = "Lane Not Available"
            ElseIf isApiDelay And isKpiDelay Then
                scenario = "Delay in Both"
            ElseIf isApiDelay And Not isKpiDelay Then
                scenario = "Delay in DCT Only"
            ElseIf Not isApiDelay And isKpiDelay Then
                scenario = "Delay in KPI Only"
            End If
            
            If scenario <> "" And scenario <> "Lane Not Available" Then
                Dim cStatus As String, cReason As String, cAcc As String
                cStatus = "": cReason = "": cAcc = ""
                
                If Trim(kpiDCode) = "" Then
                    If scenario = "Delay in DCT Only" Then
                        kpiDCode = "N/A": cStatus = "N/A": cReason = "N/A": cAcc = "N/A"
                    Else
                        kpiDCode = "Missing": cStatus = "Missing": cReason = "Missing": cAcc = "Missing"
                    End If
                Else
                    If dictDelayCodes.exists(kpiDCode) Then
                        cStatus = dictDelayCodes(kpiDCode)(0)
                        cReason = dictDelayCodes(kpiDCode)(1)
                        cAcc = dictDelayCodes(kpiDCode)(2)
                    Else
                        cStatus = "Unmapped": cReason = "Unmapped": cAcc = "Unmapped"
                    End If
                End If
                
                outDelay(dRow, 1) = key
                outDelay(dRow, 2) = scenario
                outDelay(dRow, 3) = apiSC
                outDelay(dRow, 4) = kpiSC
                outDelay(dRow, 5) = contractedDays
                outDelay(dRow, 6) = IIf(apiCompareDate > 0 And apiSCDate > 0, CLng(apiCompareDate) - CLng(apiSCDate), "N/A")
                outDelay(dRow, 7) = IIf(IsEmpty(contractedDate), "N/A", contractedDate)
                outDelay(dRow, 8) = IIf(apiCompareDate > 0, apiCompareDate, "Missing")
                outDelay(dRow, 9) = IIf(kpiCompareDate > 0, kpiCompareDate, "Missing")
                outDelay(dRow, 10) = kpiDCode
                
                If Not dictSeenCodes.exists(kpiDCode) Then dictSeenCodes.Add kpiDCode, 1
                
                outDelay(dRow, 11) = cReason
                outDelay(dRow, 12) = cAcc
                outDelay(dRow, 13) = IIf(scenario = "Delay in DCT Only", "N/A", cStatus)
                outDelay(dRow, 14) = IIf(hasSCDisc, "Yes", "No")
                outDelay(dRow, 15) = IIf(hasPODDisc, "Yes", "No")
                
                dRow = dRow + 1
            End If
        End If
    Next key
    
    Dim mRow2 As Long: mRow2 = 1
    For Each key In dictKPI.Keys
        If Not dictAPI.exists(key) Then
            outMissing(mRow2, 2) = key
            mRow2 = mRow2 + 1
        End If
    Next key
    
    ' ==========================================
    ' 9b. COMPILE LANE MAPPING AUDIT DATA
    ' ==========================================
    Dim outAudit() As Variant
    ReDim outAudit(1 To dictKPI.Count + 1, 1 To 10)
    Dim auditRow As Long: auditRow = 1
    Dim kKey As Variant, kVals As Variant
    
    For Each kKey In dictKPI.Keys
        kVals = dictKPI(kKey)
        
        Dim aCountryName As String, aPostName As String, aCityName As String, aSvc As String
        aSvc = kVals(0): aCountryName = kVals(9): aPostName = kVals(10): aCityName = kVals(11)
        
        Dim aDerivedCountry As String, aDerivedDest As String, aDerivedOrig As String
        If Len(aCountryName) = 2 Then
            aDerivedCountry = UCase(aCountryName)
        ElseIf dictCountryMap.exists(LCase(aCountryName)) Then
            aDerivedCountry = dictCountryMap(LCase(aCountryName))
        Else
            aDerivedCountry = "Unmapped Country"
        End If
        
        If dictDestMap.exists(LCase(aCityName)) Then
            aDerivedDest = dictDestMap(LCase(aCityName))
        Else
            aDerivedDest = "Unmapped City"
        End If
        
        aDerivedOrig = GetOriginRegion(aDerivedCountry, aPostName, dictOrigRegs)
        
        Dim aLaneKey As String
        aLaneKey = UCase(aDerivedCountry) & "|" & UCase(aDerivedOrig) & "|" & UCase(aDerivedDest) & "|" & CleanSvc(aSvc)
        
        Dim aContractedDays As Variant
        If dictRateCard.exists(aLaneKey) Then
            aContractedDays = dictRateCard(aLaneKey)
        Else
            aContractedDays = "Lane Not Available"
        End If
        
        outAudit(auditRow, 1) = kKey
        outAudit(auditRow, 2) = aContractedDays
        outAudit(auditRow, 3) = aCountryName
        outAudit(auditRow, 4) = aDerivedCountry
        outAudit(auditRow, 5) = aPostName
        outAudit(auditRow, 6) = aDerivedOrig
        outAudit(auditRow, 7) = aCityName
        outAudit(auditRow, 8) = aDerivedDest
        outAudit(auditRow, 9) = aSvc
        outAudit(auditRow, 10) = aLaneKey
        
        auditRow = auditRow + 1
    Next kKey

    ' ==========================================
    ' 10. Write Results to New Workbook
    ' ==========================================
    Dim wbOut As Workbook
    Set wbOut = Workbooks.Add
    Set wsOutput = wbOut.Sheets(1)
    wsOutput.Name = "Discrepancies_" & Replace(userInput, "/", "-")
    wsOutput.Cells.Font.Color = vbBlack
    
    wsOutput.Range("A1:B1").Merge: wsOutput.Range("A1").Value = "Shipment Count Summary"
    wsOutput.Range("D1:E1").Merge: wsOutput.Range("D1").Value = "Missing HBL/HAWB"
    wsOutput.Range("G1:J1").Merge: wsOutput.Range("G1").Value = "Service Level Discrepancies"
    wsOutput.Range("L1:O1").Merge: wsOutput.Range("L1").Value = "Start Clock Discrepancies"
    wsOutput.Range("Q1:T1").Merge: wsOutput.Range("Q1").Value = "Actual Pick-up Date Discrepancies"
    wsOutput.Range("V1:Y1").Merge: wsOutput.Range("V1").Value = "Actual Time of Departure Discrepancies"
    wsOutput.Range("AA1:AD1").Merge: wsOutput.Range("AA1").Value = "Actual Time of Arrival Discrepancies"
    wsOutput.Range("AF1:AI1").Merge: wsOutput.Range("AF1").Value = "Proof of Delivery Date Discrepancies"

    wsOutput.Range("A2:B2").Value = Array("Metric", "Value")
    wsOutput.Range("D2:E2").Value = Array("Missing in KPI", "Missing in API")
    wsOutput.Range("G2:J2").Value = Array("HBL Number", "API Service", "KPI Service", "Comment")
    wsOutput.Range("L2:O2").Value = Array("HBL Number", "API Start Clock", "KPI Start Clock", "Comment")
    wsOutput.Range("Q2:T2").Value = Array("HBL Number", "API APD", "KPI APD", "Comment")
    wsOutput.Range("V2:Y2").Value = Array("HBL Number", "API ATD", "KPI ATD", "Comment")
    wsOutput.Range("AA2:AD2").Value = Array("HBL Number", "API ATA", "KPI ATA", "Comment")
    wsOutput.Range("AF2:AI2").Value = Array("HBL Number", "API Date", "KPI Date", "Comment")

    Dim rMis As Long, rSvc As Long, rSC As Long, rAPD As Long, rATD As Long, rATA As Long, rPOD As Long
    rMis = WorksheetFunction.Max(mRow, mRow2) - 1: If rMis < 1 Then rMis = 1
    rSvc = sRow - 1: If rSvc < 1 Then rSvc = 1
    rSC = cRow - 1: If rSC < 1 Then rSC = 1
    rAPD = aRow - 1: If rAPD < 1 Then rAPD = 1
    rATD = tRow - 1: If rATD < 1 Then rATD = 1
    rATA = rRow - 1: If rATA < 1 Then rATA = 1
    rPOD = pRow - 1: If rPOD < 1 Then rPOD = 1

    wsOutput.Range("A3").Value = "DCT (API):": wsOutput.Range("B3").Value = apiCount
    wsOutput.Range("A4").Value = "LSP KPI:": wsOutput.Range("B4").Value = kpiCount
    
    Dim diffCount As Long: diffCount = Abs(apiCount - kpiCount)
    wsOutput.Range("A5").Value = "Difference:": wsOutput.Range("B5").Value = diffCount
    
    Dim varPercent As Double, maxCount As Long
    maxCount = WorksheetFunction.Max(kpiCount, apiCount)
    If maxCount > 0 Then varPercent = diffCount / maxCount Else varPercent = 0
    wsOutput.Range("A6").Value = "Variance %:": wsOutput.Range("B6").Value = Format(varPercent, "0.00%")

    Dim missingInKPI As Long, missingInAPI As Long, totalUnique As Long, matchingShipments As Long
    Dim matchPercent As Double, matchSeverity As String, matchRemark As String
    missingInKPI = mRow - 1: missingInAPI = mRow2 - 1
    totalUnique = kpiCount + missingInKPI: matchingShipments = kpiCount - missingInAPI
    If totalUnique > 0 Then matchPercent = matchingShipments / totalUnique Else matchPercent = 0
    
    If matchPercent = 1 Then
        matchSeverity = "No Issue": matchRemark = "No action needed"
    ElseIf matchPercent >= 0.95 Then
        matchSeverity = "Non-Critical Issue": matchRemark = "Manageable but must be reported and tracked"
    Else
        matchSeverity = "Critical Issue": matchRemark = "Immediate escalation required"
    End If
    
    wsOutput.Range("A8").Value = "Total Unique Shipments:": wsOutput.Range("B8").Value = totalUnique
    wsOutput.Range("A9").Value = "No. of Matching Shipments:": wsOutput.Range("B9").Value = matchingShipments
    wsOutput.Range("A10").Value = "Match %:": wsOutput.Range("B10").Value = Format(matchPercent, "0.00%")
    
    With wsOutput.Range("B10")
        .Font.Bold = True
        If matchPercent = 1 Then
            .Interior.Color = RGB(198, 239, 206): .Font.Color = RGB(0, 97, 0)
        ElseIf matchPercent >= 0.95 Then
            .Interior.Color = RGB(255, 235, 156): .Font.Color = RGB(156, 101, 0)
        Else
            .Interior.Color = RGB(255, 199, 206): .Font.Color = RGB(156, 0, 6)
        End If
    End With
    
    wsOutput.Range("A12").Value = "Severity Level:": wsOutput.Range("B12").Value = matchSeverity
    wsOutput.Range("A13").Value = "Remark:": wsOutput.Range("B13").Value = matchRemark

    If mRow > 1 Or mRow2 > 1 Then wsOutput.Range("D3").Resize(rMis, 2).Value = outMissing
    If sRow > 1 Then wsOutput.Range("G3").Resize(rSvc, 4).Value = outSvc
    If cRow > 1 Then wsOutput.Range("L3").Resize(rSC, 4).Value = outSC
    If aRow > 1 Then wsOutput.Range("Q3").Resize(rAPD, 4).Value = outAPD
    If tRow > 1 Then wsOutput.Range("V3").Resize(rATD, 4).Value = outATD
    If rRow > 1 Then wsOutput.Range("AA3").Resize(rATA, 4).Value = outATA
    If pRow > 1 Then wsOutput.Range("AF3").Resize(rPOD, 4).Value = outPOD

    Dim lo As ListObject
    Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("A2:B13"), , xlYes): lo.Name = "TblSummary": lo.TableStyle = ""
    If mRow > 1 Or mRow2 > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("D2:E" & 2 + rMis), , xlYes): lo.Name = "TblMissing": lo.TableStyle = ""
    If sRow > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("G2:J" & 2 + rSvc), , xlYes): lo.Name = "TblService": lo.TableStyle = ""
    If cRow > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("L2:O" & 2 + rSC), , xlYes): lo.Name = "TblStartClock": lo.TableStyle = ""
    If aRow > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("Q2:T" & 2 + rAPD), , xlYes): lo.Name = "TblAPD": lo.TableStyle = ""
    If tRow > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("V2:Y" & 2 + rATD), , xlYes): lo.Name = "TblATD": lo.TableStyle = ""
    If rRow > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("AA2:AD" & 2 + rATA), , xlYes): lo.Name = "TblATA": lo.TableStyle = ""
    If pRow > 1 Then Set lo = wsOutput.ListObjects.Add(xlSrcRange, wsOutput.Range("AF2:AI" & 2 + rPOD), , xlYes): lo.Name = "TblPOD": lo.TableStyle = ""
    
    With wsOutput.Range("A1:B1, D1:E1, G1:J1, L1:O1, Q1:T1, V1:Y1, AA1:AD1, AF1:AI1")
        .Interior.ThemeColor = xlThemeColorAccent3: .Interior.TintAndShade = 0.4
        .Font.Bold = True: .HorizontalAlignment = xlCenter
    End With
    With wsOutput.Range("A2:B2, D2:E2, G2:J2, L2:O2, Q2:T2, V2:Y2, AA2:AD2, AF2:AI2")
        .Interior.ThemeColor = xlThemeColorAccent1: .Interior.TintAndShade = 0.6: .Font.Bold = True
    End With
    
    wsOutput.Range("A3:A13").Font.Bold = True
    wsOutput.Range("A2:AI" & wsOutput.Rows.Count).HorizontalAlignment = xlLeft
    wsOutput.Columns("M:N").NumberFormat = "dd/mm/yyyy"
    wsOutput.Columns("R:S").NumberFormat = "dd/mm/yyyy"
    wsOutput.Columns("W:X").NumberFormat = "dd/mm/yyyy"
    wsOutput.Columns("AB:AC").NumberFormat = "dd/mm/yyyy"
    wsOutput.Columns("AG:AH").NumberFormat = "dd/mm/yyyy"
    
    wsOutput.Columns.AutoFit
    wsOutput.Columns("C").ColumnWidth = 3: wsOutput.Columns("F").ColumnWidth = 3
    wsOutput.Columns("K").ColumnWidth = 3: wsOutput.Columns("P").ColumnWidth = 3
    wsOutput.Columns("U").ColumnWidth = 3: wsOutput.Columns("Z").ColumnWidth = 3
    wsOutput.Columns("AE").ColumnWidth = 3
    
    Dim noErrColor As Long, noErrFont As Long
    noErrColor = RGB(198, 239, 206): noErrFont = RGB(0, 97, 0)
    
    If mRow = 1 And mRow2 = 1 Then
        With wsOutput.Range("D3:E3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If
    If sRow = 1 Then
        With wsOutput.Range("G3:J3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If
    If cRow = 1 Then
        With wsOutput.Range("L3:O3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If
    If aRow = 1 Then
        With wsOutput.Range("Q3:T3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If
    If tRow = 1 Then
        With wsOutput.Range("V3:Y3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If
    If rRow = 1 Then
        With wsOutput.Range("AA3:AD3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If
    If pRow = 1 Then
        With wsOutput.Range("AF3:AI3")
            .Merge: .Value = "NO ERRORS FOUND": .HorizontalAlignment = xlCenter
            .Interior.Color = noErrColor: .Font.Color = noErrFont: .Font.Bold = True: .Borders.LineStyle = xlContinuous
        End With
    End If

    wsOutput.Activate
    ActiveWindow.SplitRow = 2: ActiveWindow.FreezePanes = True
    
