    shpKPI.Fill.ForeColor.RGB = RGB(198, 239, 206)
    shpKPI.Line.Visible = msoFalse
    shpKPI.OnAction = "'" & ThisWorkbook.Name & "'!ToggleKPIFilter"
    
    Dim shpSC As Shape
    Set shpSC = wsDelayTab.Shapes.AddShape(msoShapeRoundedRectangle, 0, 0, 210, 25)
    shpSC.Name = "btnSC"
    shpSC.TextFrame.Characters.Text = "Start Clock Discrepancies: Listed"
    shpSC.TextFrame.VerticalAlignment = xlVAlignCenter
    shpSC.TextFrame.HorizontalAlignment = xlHAlignCenter
    shpSC.TextFrame.Characters.Font.Color = RGB(0, 97, 0)
